# Copy to .env.analytics and fill all values.

# --- Google Analytics 4 ---
GA4_PROPERTY_ID=123456789

# --- Service account Google Cloud ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=analytics-bot@project-id.iam.gserviceaccount.com
# Keep \n escapes if you paste on one line.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nABC...\n-----END PRIVATE KEY-----\n"

# --- Search Console property ---
# Example URL-prefix property:
GSC_SITE_URL=https://msd-media.com/
# Example domain property:
# GSC_SITE_URL=sc-domain:msd-media.com

# --- SMTP ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# --- Mail routing ---
MAIL_FROM=agence@msd-media.com
MAIL_TO=soldan.maxens@gmail.com

# Optional
REPORT_DAYS=7
